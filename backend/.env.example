# Copy to .env and update values if needed
NODE_ENV=development
PORT=4000

# MySQL (docker-compose exposes to host at localhost)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dack
DB_USER=root
DB_PASS=root

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
ROOMS_CACHE_TTL_SECONDS=60

# CORS
CORS_ORIGIN=http://localhost:5173
